  "private": true,
  "type": "module",
  "description": "Aaron Cordova - JavaScript Developer resume built with React!",
  "keywords": ["aaron", "cordova", "qodesmith", "resume", "react"],
  "scripts": {
    "dev": "bun --hot src/index.html",
    "start": "NODE_ENV=production bun src/index.html",
    "build": "bun run build.ts",
